class Solution {
    public void moveZeroes(int[] nums) {
        int index = 0;
        // move all elements to first
        for (int i =0; i< nums.length;i++){
            if(nums[i]!=0){
                nums [index]=nums [i];
                index++;

            }
        }
        // fill remaining places with zero
        while(index<nums.length){
            nums [ index]=0;
            index++;
        }

        
    }
}
